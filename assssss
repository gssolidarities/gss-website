<script>
// LOADER
window.addEventListener('load',()=>{setTimeout(()=>document.getElementById('loader').classList.add('done'),2800)});

// PROGRESS BAR
const prog=document.getElementById('progress');
window.addEventListener('scroll',()=>{
  const h=document.documentElement.scrollHeight-window.innerHeight;
  prog.style.width=(window.scrollY/h*100)+'%';
});

// CURSOR
const dot=document.getElementById('curDot'),ring=document.getElementById('curRing');
let mx=0,my=0,cx=0,cy=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
(function aC(){cx+=(mx-cx)*.22;cy+=(my-cy)*.22;rx+=(mx-rx)*.1;ry+=(my-ry)*.1;dot.style.left=cx+'px';dot.style.top=cy+'px';ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(aC)})();
document.querySelectorAll('a,button,.enc,.member,.det,.cta-btn').forEach(el=>{
  el.addEventListener('mouseenter',()=>{dot.classList.add('h');ring.classList.add('h')});
  el.addEventListener('mouseleave',()=>{dot.classList.remove('h');ring.classList.remove('h')});
});

// MAGNETIC HOVER on encounter cards
document.querySelectorAll('[data-magnetic]').forEach(card=>{
  card.addEventListener('mousemove',e=>{
    const r=card.getBoundingClientRect();
    const x=(e.clientX-r.left-r.width/2)/r.width*12;
    const y=(e.clientY-r.top-r.height/2)/r.height*12;
    card.style.transform=`translate(${x}px,${y}px)`;
  });
  card.addEventListener('mouseleave',()=>{card.style.transform='translate(0,0)'});
});

// PARTICLES
const pc=document.getElementById('particles'),pctx=pc.getContext('2d');
function rP(){pc.width=innerWidth;pc.height=innerHeight}rP();addEventListener('resize',rP);
const pts=Array.from({length:50},()=>({x:Math.random()*innerWidth,y:Math.random()*innerHeight,vx:(Math.random()-.5)*.25,vy:(Math.random()-.5)*.25,r:Math.random()*1.2+.4,a:Math.random()*.12+.02}));
(function dP(){pctx.clearRect(0,0,pc.width,pc.height);pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0)p.x=pc.width;if(p.x>pc.width)p.x=0;if(p.y<0)p.y=pc.height;if(p.y>pc.height)p.y=0;pctx.beginPath();pctx.arc(p.x,p.y,p.r,0,Math.PI*2);pctx.fillStyle=`rgba(232,160,64,${p.a})`;pctx.fill()});for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);if(d<140){pctx.beginPath();pctx.moveTo(pts[i].x,pts[i].y);pctx.lineTo(pts[j].x,pts[j].y);pctx.strokeStyle=`rgba(232,160,64,${.035*(1-d/140)})`;pctx.lineWidth=.5;pctx.stroke()}}requestAnimationFrame(dP)})();

// HERO CANVAS - Solidarity Network
const hc=document.getElementById('heroCanvas'),hx=hc.getContext('2d');
function rH(){hc.width=hc.parentElement.offsetWidth;hc.height=hc.parentElement.offsetHeight}rH();addEventListener('resize',rH);
const nodes=[{l:'Chiapas',x:.14,y:.42,c:'#e8a040'},{l:'Minneapolis',x:.24,y:.26,c:'#c94040'},{l:'Queens',x:.28,y:.36,c:'#d070a0'},{l:'Honduras',x:.17,y:.58,c:'#5a6e4a'},{l:'Palestine',x:.58,y:.4,c:'#c94040'},{l:'Bethlehem',x:.6,y:.47,c:'#c94040'},{l:'Afghanistan',x:.68,y:.34,c:'#3a8c7e'},{l:'South Asia',x:.73,y:.52,c:'#e8a040'},{l:'Nepal',x:.7,y:.44,c:'#8b6b4a'},{l:'Turtle Island',x:.19,y:.3,c:'#5a6e4a'}];
const links=[[0,4],[0,9],[1,4],[1,5],[2,3],[3,8],[4,6],[5,1],[6,7],[7,8],[0,1],[2,6],[3,9],[5,7]];
let t=0,mouseHeroX=0,mouseHeroY=0;
document.querySelector('.hero').addEventListener('mousemove',e=>{const r=hc.getBoundingClientRect();mouseHeroX=(e.clientX-r.left)/r.width;mouseHeroY=(e.clientY-r.top)/r.height});
(function dH(){t+=.004;hx.clearRect(0,0,hc.width,hc.height);
links.forEach(([a,b])=>{const na=nodes[a],nb=nodes[b];const ax=na.x*hc.width,ay=na.y*hc.height,bx=nb.x*hc.width,by=nb.y*hc.height;const p=Math.sin(t*2+a+b)*.5+.5;hx.beginPath();hx.moveTo(ax,ay);hx.lineTo(bx,by);hx.strokeStyle=`rgba(232,160,64,${.05+p*.06})`;hx.lineWidth=.8;hx.stroke();const tt=(t*.25+a*.1)%1;const tx=ax+(bx-ax)*tt,ty=ay+(by-ay)*tt;hx.beginPath();hx.arc(tx,ty,2,0,Math.PI*2);hx.fillStyle=`rgba(232,160,64,${.3+p*.4})`;hx.fill()});
nodes.forEach((n,i)=>{const parallax=6;const x=n.x*hc.width+Math.sin(t+i)*3+(mouseHeroX-.5)*parallax;const y=n.y*hc.height+Math.cos(t+i*1.3)*3+(mouseHeroY-.5)*parallax;const p=Math.sin(t*1.5+i)*.5+.5;const g=hx.createRadialGradient(x,y,0,x,y,28+p*12);g.addColorStop(0,n.c+'22');g.addColorStop(1,'transparent');hx.beginPath();hx.arc(x,y,28+p*12,0,Math.PI*2);hx.fillStyle=g;hx.fill();hx.beginPath();hx.arc(x,y,3.5+p*2,0,Math.PI*2);hx.fillStyle=n.c;hx.fill();hx.font='10px "Instrument Sans"';hx.fillStyle=`rgba(240,235,227,${.6+p*.25})`;hx.textAlign='center';hx.fillText(n.l,x,y+20)});
requestAnimationFrame(dH)})();

// PARALLAX LINES
const pLinesEl=document.getElementById('pLines');
for(let i=0;i<8;i++){const l=document.createElement('div');l.className='line';l.style.left=(10+i*12)+'%';l.style.opacity=(.02+Math.random()*.03);pLinesEl.appendChild(l)}

// SOLIDARITY MAP
const mc=document.getElementById('mapCanvas'),mx2=mc.getContext('2d');
function rM(){const w=document.getElementById('mapWrap');mc.width=w.offsetWidth;mc.height=w.offsetHeight}rM();addEventListener('resize',rM);
const mn=[{n:'Chiapas',x:.2,y:.52,r:6,c:'#e8a040'},{n:'Queens, NY',x:.24,y:.38,r:5,c:'#d070a0'},{n:'Minneapolis',x:.22,y:.34,r:5,c:'#c94040'},{n:'Honduras',x:.19,y:.57,r:5,c:'#5a6e4a'},{n:'Palestine',x:.54,y:.42,r:6,c:'#c94040'},{n:'Bethlehem',x:.55,y:.44,r:4,c:'#c94040'},{n:'Afghanistan',x:.64,y:.37,r:5,c:'#3a8c7e'},{n:'Nepal',x:.68,y:.42,r:5,c:'#e8a040'},{n:'South Asia',x:.66,y:.52,r:4,c:'#8b6b4a'},{n:'Turtle Island',x:.18,y:.3,r:5,c:'#5a6e4a'}];
const ml=[[0,4],[1,4],[2,5],[3,7],[6,8],[0,9],[1,3],[2,4],[6,7],[7,8],[0,2],[5,6]];
let mt=0,mapMX=.5,mapMY=.5;
document.getElementById('mapWrap').addEventListener('mousemove',e=>{const r=mc.getBoundingClientRect();mapMX=(e.clientX-r.left)/r.width;mapMY=(e.clientY-r.top)/r.height});
(function dM(){mt+=.003;mx2.clearRect(0,0,mc.width,mc.height);
mx2.strokeStyle='rgba(240,235,227,0.025)';mx2.lineWidth=.5;for(let i=0;i<mc.width;i+=50){mx2.beginPath();mx2.moveTo(i,0);mx2.lineTo(i,mc.height);mx2.stroke()}for(let i=0;i<mc.height;i+=50){mx2.beginPath();mx2.moveTo(0,i);mx2.lineTo(mc.width,i);mx2.stroke()}
ml.forEach(([a,b],idx)=>{const na=mn[a],nb=mn[b];const ax=na.x*mc.width,ay=na.y*mc.height,bx=nb.x*mc.width,by=nb.y*mc.height;const midX=(ax+bx)/2,midY=(ay+by)/2-35;const p=Math.sin(mt*1.5+idx)*.5+.5;mx2.beginPath();mx2.moveTo(ax,ay);mx2.quadraticCurveTo(midX,midY,bx,by);mx2.strokeStyle=`rgba(58,140,126,${.08+p*.1})`;mx2.lineWidth=1;mx2.stroke();const tt=(mt*.18+idx*.07)%1;const px=(1-tt)*(1-tt)*ax+2*(1-tt)*tt*midX+tt*tt*bx;const py=(1-tt)*(1-tt)*ay+2*(1-tt)*tt*midY+tt*tt*by;mx2.beginPath();mx2.arc(px,py,2.5,0,Math.PI*2);mx2.fillStyle=`rgba(58,140,126,${.35+p*.45})`;mx2.fill()});
mn.forEach((n,i)=>{const px=4,x=n.x*mc.width+(mapMX-.5)*px,y=n.y*mc.height+(mapMY-.5)*px;const p=Math.sin(mt*2+i)*.5+.5;const rr=14+p*10;mx2.beginPath();mx2.arc(x,y,rr,0,Math.PI*2);mx2.strokeStyle=n.c+'15';mx2.lineWidth=1;mx2.stroke();const g=mx2.createRadialGradient(x,y,0,x,y,n.r*3);g.addColorStop(0,n.c+'28');g.addColorStop(1,'transparent');mx2.beginPath();mx2.arc(x,y,n.r*3,0,Math.PI*2);mx2.fillStyle=g;mx2.fill();mx2.beginPath();mx2.arc(x,y,n.r*(.8+p*.25),0,Math.PI*2);mx2.fillStyle=n.c;mx2.fill();mx2.font='10px "Instrument Sans"';mx2.fillStyle='rgba(240,235,227,0.7)';mx2.textAlign='center';mx2.fillText(n.n,x,y+n.r+16)});
requestAnimationFrame(dM)})();

// SCROLL REVEAL
const rvs=document.querySelectorAll('.rv');
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');obs.unobserve(e.target)}})},{threshold:.1,rootMargin:'0px 0px -30px 0px'});
rvs.forEach(el=>obs.observe(el));

// NAV AUTOHIDE
let lastS=0;const navE=document.querySelector('nav');
addEventListener('scroll',()=>{const c=scrollY;navE.style.transform=c>lastS&&c>100?'translateY(-100%)':'translateY(0)';lastS=c});

// SMOOTH PARALLAX on scroll for sections
let scrollY2=0;
addEventListener('scroll',()=>{scrollY2=scrollY});
</script>
