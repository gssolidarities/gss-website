<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>About — Global South Solidarities Anarchive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600;1,700&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0e0c0b;--s1:#161412;--s2:#1e1b18;--s3:#262220;
  --text:#f0ebe3;--muted:rgba(240,235,227,.92);--dim:rgba(240,235,227,.55);
  --saffron:#e8a040;--saffron-d:rgba(232,160,64,.1);--saffron-g:rgba(232,160,64,.3);
  --crimson:#c94040;--teal:#3a8c7e;--earth:#8b6b4a;--moss:#5a6e4a;
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'Trebuchet MS','Instrument Sans',system-ui,sans-serif;
  --ease:cubic-bezier(.25,.46,.45,.94);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{background:var(--bg);color:var(--text);font-family:var(--sans);line-height:1.65;overflow-x:hidden;cursor:none}
a{color:inherit;text-decoration:none}
::selection{background:var(--saffron);color:#0e0c0b}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--saffron);border-radius:3px}

/* CURSOR */
.cur{position:fixed;pointer-events:none;z-index:10000;mix-blend-mode:difference}
#curDot{width:8px;height:8px;background:var(--saffron);border-radius:50%;transform:translate(-50%,-50%);transition:width .15s,height .15s}
#curRing{width:40px;height:40px;border:1px solid rgba(232,160,64,.35);border-radius:50%;transform:translate(-50%,-50%);transition:all .15s ease}
#curDot.h{width:20px;height:20px;background:rgba(232,160,64,.5)}
#curRing.h{width:60px;height:60px;border-color:var(--saffron)}

/* GRAIN */
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:9998;opacity:.035;
background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}

/* PROGRESS BAR */
#progress{position:fixed;top:0;left:0;height:2px;background:var(--saffron);z-index:10001;transition:width .1s linear;box-shadow:0 0 8px var(--saffron-g)}

/* LOADER */
.loader{position:fixed;inset:0;background:#0a0908;z-index:10002;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;transition:opacity 1s var(--ease),visibility 1s}
.loader.done{opacity:0;visibility:hidden;pointer-events:none}
.loader-glyph{font-family:var(--serif);font-size:clamp(48px,10vw,100px);font-weight:300;font-style:italic;color:var(--saffron);opacity:0;animation:fadeUp 1s var(--ease) .3s forwards}
.loader-sub{font-size:12px;letter-spacing:.5em;text-transform:uppercase;color:var(--dim);font-family:var(--sans);opacity:0;animation:fadeUp .8s var(--ease) .8s forwards}
.loader-bar{width:200px;height:1px;background:var(--dim);overflow:hidden;border-radius:1px;margin-top:12px}
.loader-fill{height:100%;background:var(--saffron);width:0;animation:load 2.5s var(--ease) forwards}
@keyframes load{to{width:100%}}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:18px 40px;display:flex;align-items:center;justify-content:space-between;backdrop-filter:blur(24px);background:rgba(14,12,11,.75);border-bottom:1px solid var(--dim);transition:transform .4s var(--ease)}
.nav-logo{font-family:var(--serif);font-size:18px;font-weight:600;letter-spacing:.05em;display:flex;align-items:center;gap:10px}
.nav-logo .dot{width:8px;height:8px;background:var(--saffron);border-radius:50%;animation:glow 2.5s ease infinite}
@keyframes glow{0%,100%{box-shadow:0 0 4px var(--saffron-g)}50%{box-shadow:0 0 18px var(--saffron-g)}}
.nav-links{display:flex;gap:28px;font-size:12px;font-family:var(--sans);letter-spacing:.08em;text-transform:uppercase;font-weight:500}
.nav-links a{color:var(--text);transition:color .3s;position:relative}
.nav-links a:hover{color:var(--saffron)}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:1px;background:var(--saffron);transition:width .3s}
.nav-links a:hover::after{width:100%}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;padding:140px 60px 100px;overflow:hidden}
#heroCanvas{position:absolute;inset:0;z-index:0}
.hero-content{position:relative;z-index:2;max-width:880px}
.hero-label{font-size:11px;letter-spacing:.45em;text-transform:uppercase;color:var(--saffron);font-weight:600;margin-bottom:28px;font-family:var(--sans);display:flex;align-items:center;gap:14px;opacity:0;animation:fadeUp .8s var(--ease) 1s forwards}
.hero-label::before{content:'';width:40px;height:1px;background:var(--saffron)}
.hero h1{font-family:var(--serif);font-size:clamp(40px,6.5vw,86px);font-weight:300;line-height:1.06;margin-bottom:36px;opacity:0;animation:fadeUp 1.2s var(--ease) 1.2s forwards}
.hero h1 em{font-style:italic;color:var(--saffron);font-weight:400}
.hero-sub{font-size:clamp(16px,1.6vw,19px);color:var(--muted);max-width:640px;line-height:1.8;font-family:var(--sans);opacity:0;animation:fadeUp 1s var(--ease) 1.6s forwards}
.hero-gradient{position:absolute;bottom:0;left:0;right:0;height:200px;background:linear-gradient(to top,var(--bg),transparent);z-index:1}
.hero-scroll{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;color:var(--dim);font-size:10px;letter-spacing:.25em;text-transform:uppercase;animation:bob 2.5s ease infinite}
@keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(10px)}}
.hero-scroll .arr{width:1px;height:44px;background:linear-gradient(to bottom,var(--saffron),transparent)}

/* PARALLAX LINES */
.parallax-lines{position:absolute;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.parallax-lines .line{position:absolute;width:1px;height:100%;background:linear-gradient(to bottom,transparent,rgba(232,160,64,.04),transparent);top:0}

/* TICKER */
.ticker{overflow:hidden;padding:16px 0;border-top:1px solid rgba(232,160,64,.2);border-bottom:1px solid rgba(232,160,64,.2);white-space:nowrap;position:relative;z-index:2;background:rgba(14,12,11,.9)}
.ticker-track{display:inline-flex;animation:marquee 50s linear infinite}
.ticker-item{font-family:var(--sans);font-size:14px;font-weight:400;letter-spacing:.18em;text-transform:uppercase;color:var(--text);padding:0 24px;flex-shrink:0}
.ticker-item .sep{color:var(--saffron);margin-left:24px}
@keyframes marquee{to{transform:translateX(-50%)}}

/* SECTIONS */
section{padding:120px 60px;position:relative}
.sec-label{font-size:11px;letter-spacing:.45em;text-transform:uppercase;color:var(--saffron);font-weight:600;font-family:var(--sans);margin-bottom:16px;display:flex;align-items:center;gap:14px}
.sec-label::before{content:'';width:40px;height:1px;background:var(--saffron)}
.sec-title{font-family:var(--serif);font-size:clamp(30px,4.5vw,54px);font-weight:300;line-height:1.15;margin-bottom:48px}
.sec-title em{font-style:italic;color:var(--saffron)}

/* WHAT IS GSS */
.what-is{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.what-left{position:sticky;top:120px}
.what-right{display:flex;flex-direction:column;gap:40px}
.txt{font-size:17px;line-height:1.85;color:var(--text);font-family:var(--sans)}
.txt p+p{margin-top:20px}
.hl{color:var(--saffron);font-weight:500}
.pull{font-family:var(--serif);font-size:clamp(20px,2.5vw,30px);font-weight:300;font-style:italic;line-height:1.55;color:var(--text);padding:36px 0;border-top:1px solid var(--dim);border-bottom:1px solid var(--dim);position:relative}
.pull::before{content:'\201C';font-size:80px;color:var(--saffron);opacity:.25;position:absolute;top:4px;left:-6px;font-family:var(--serif);line-height:1}
.divider{width:60px;height:1px;background:var(--dim);margin:12px 0}


/* EMBEDDED PHOTOS */
.embedded-photo{width:100%;border-radius:4px;overflow:hidden;margin-bottom:16px;border:1px solid rgba(232,160,64,.15);background:var(--s2);transition:all .4s var(--ease)}
.embedded-photo:hover{border-color:rgba(232,160,64,.35);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.embedded-photo img{width:100%;height:auto;display:block;filter:grayscale(.2) contrast(1.05);transition:filter .6s}
.embedded-photo:hover img{filter:grayscale(0) contrast(1.1)}
.photo-credit{font-size:11px;line-height:1.6;color:var(--dim);font-family:var(--sans);padding:12px 16px;font-style:italic;background:rgba(14,12,11,.5)}

/* ENCOUNTERS */
.encounters{background:var(--s1);border-top:1px solid var(--dim);border-bottom:1px solid var(--dim)}
.enc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;margin-top:56px}
.enc-grid>.enc:last-child:nth-child(odd){grid-column:1/-1}
.enc{background:var(--s2);padding:48px;position:relative;overflow:hidden;transition:all .5s var(--ease)}
.enc:hover{background:var(--s3)}
.enc::before{content:'';position:absolute;top:0;left:0;width:3px;height:0;background:var(--saffron);transition:height .6s var(--ease)}
.enc:hover::before{height:100%}
.enc::after{content:'';position:absolute;bottom:0;right:0;width:120px;height:120px;background:radial-gradient(circle,rgba(232,160,64,.04),transparent);transition:opacity .4s;opacity:0}
.enc:hover::after{opacity:1}
.enc-name{font-family:var(--serif);font-size:clamp(24px,2.5vw,30px);font-weight:400;margin-bottom:4px}
.enc-origin{font-size:12px;letter-spacing:.15em;font-family:var(--sans);text-transform:uppercase;color:var(--saffron);margin-bottom:18px;font-weight:600}
.enc-desc{font-size:15.5px;line-height:1.8;color:rgba(240,235,227,.9);font-family:var(--sans)}
.enc-desc em{color:var(--text);font-style:italic}
.enc-tag{display:inline-block;margin-top:18px;padding:5px 16px;border:1px solid rgba(232,160,64,.3);border-radius:20px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--saffron);transition:all .3s}
.enc:hover .enc-tag{border-color:var(--saffron);color:var(--saffron)}
.enc-num{position:absolute;top:20px;right:24px;font-family:var(--serif);font-size:60px;font-weight:300;color:rgba(240,235,227,.04);line-height:1;transition:color .4s}
.enc:hover .enc-num{color:rgba(232,160,64,.08)}

/* TRANSITION TEXT */
.transition-text{background:var(--bg);text-align:center;padding:100px 60px}
.transition-text .txt{max-width:800px;margin:0 auto;font-size:18px;line-height:1.9}

/* ANARCHIVE */
.anarchive-sec{position:relative}
.an-content{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:16px}
.an-manifesto{font-family:var(--serif);font-size:clamp(19px,2.2vw,26px);font-weight:300;line-height:1.7;font-style:italic;color:rgba(240,235,227,.95)}
.an-manifesto span{color:var(--saffron);font-style:normal;font-weight:500}
.an-details{display:flex;flex-direction:column;gap:28px}
.det{padding:20px 24px;border-left:2px solid var(--dim);transition:border-color .3s,background .3s;border-radius:0 4px 4px 0}
.det:hover{border-color:var(--saffron);background:var(--saffron-d)}
.det h4{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--saffron);margin-bottom:10px;font-weight:600;font-family:var(--sans)}
.det p{font-size:15.5px;line-height:1.8;color:var(--text);font-family:var(--sans)}

/* TEAM */
.team-sec{background:var(--s1);border-top:1px solid var(--dim)}
.team-grid{display:flex;flex-direction:column;gap:3px;margin-top:56px}
.member{background:var(--bg);padding:56px;display:grid;grid-template-columns:280px 1fr;gap:48px;align-items:start;position:relative;overflow:hidden;transition:background .5s var(--ease)}
.member:hover{background:var(--s2)}
.member-photo{width:100%;aspect-ratio:.85;background:var(--s2);border-radius:4px;overflow:hidden;position:relative}
.member-photo::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,transparent 50%,rgba(232,160,64,.12));mix-blend-mode:overlay;transition:opacity .4s}
.member:hover .member-photo::after{opacity:0}
.member-photo img{width:100%;height:100%;object-fit:cover;filter:grayscale(.35) contrast(1.05);transition:filter .6s,transform .6s}
.member:hover .member-photo img{filter:grayscale(0);transform:scale(1.03)}
.member-info h3{font-family:var(--serif);font-size:clamp(28px,3vw,38px);font-weight:400;margin-bottom:6px}
.member-role{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--saffron);margin-bottom:20px;font-weight:600;font-family:var(--sans)}
.member-bio{font-size:15.5px;line-height:1.85;color:var(--text);font-family:var(--sans)}
.member-bio em{color:var(--text);font-style:italic}
.member-tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:24px}
.member-tags span{padding:5px 14px;border:1px solid rgba(232,160,64,.3);border-radius:20px;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--saffron);transition:all .3s}
.member:hover .member-tags span{border-color:rgba(232,160,64,.4);color:var(--text)}

/* SOLIDARITY MAP */
.map-sec{position:relative;overflow:hidden}
.map-wrap{width:100%;height:520px;background:var(--s1);border-radius:8px;border:1px solid var(--dim);position:relative;overflow:hidden;margin-top:40px}
.map-wrap canvas{width:100%;height:100%}
.map-legend{position:absolute;bottom:16px;right:16px;background:rgba(14,12,11,.92);border:1px solid var(--dim);border-radius:6px;padding:14px 18px;display:flex;flex-direction:column;gap:8px}
.leg-item{display:flex;align-items:center;gap:10px;font-size:11px;color:var(--text);font-family:var(--sans)}
.leg-dot{width:7px;height:7px;border-radius:50%}

/* CTA */
.cta{text-align:center;padding:140px 60px;position:relative}
.cta::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:1px;height:80px;background:linear-gradient(to bottom,transparent,var(--saffron),transparent)}
.cta-btn{display:inline-flex;align-items:center;gap:12px;padding:18px 48px;background:transparent;border:1px solid var(--saffron);color:var(--saffron);font-size:12px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;border-radius:4px;transition:all .4s var(--ease);margin-top:40px;font-family:'Trebuchet MS',var(--sans)}
.cta-btn:hover{background:var(--saffron);color:var(--bg);box-shadow:0 0 50px var(--saffron-g)}
.cta-btn .arr{transition:transform .3s}
.cta-btn:hover .arr{transform:translateX(6px)}

/* FOOTER */
footer{padding:48px 60px;border-top:1px solid var(--dim);display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--dim)}
.foot-left{display:flex;flex-direction:column;gap:4px}
.foot-links{display:flex;gap:24px}
.foot-links a{color:var(--text);transition:color .3s;font-family:var(--sans)}
.foot-links a:hover{color:var(--saffron)}

/* REVEAL */
.rv{opacity:0;transform:translateY(44px);transition:opacity .9s var(--ease),transform .9s var(--ease)}
.rv.vis{opacity:1;transform:none}
.rv-d1{transition-delay:.12s}.rv-d2{transition-delay:.24s}.rv-d3{transition-delay:.36s}.rv-d4{transition-delay:.48s}.rv-d5{transition-delay:.6s}

/* MAGNETIC HOVER on encounter cards */
.enc{transform:translate(0,0);transition:transform .3s ease,background .5s var(--ease)}

/* RESPONSIVE */
@media(max-width:1024px){
  section{padding:80px 28px}
  .what-is,.an-content{grid-template-columns:1fr}
  .what-left{position:static}
  .enc-grid{grid-template-columns:1fr}
  .hero{padding:120px 28px 80px}
  nav{padding:14px 20px}
  .nav-links{display:none}
  .member{grid-template-columns:1fr;gap:32px}
  .member-photo{max-width:320px}
}
@media(max-width:640px){
  section{padding:60px 16px}
  .hero{padding:100px 16px 60px}
  .enc{padding:28px}
  .member{padding:32px}
  .transition-text{padding:60px 20px}
}

/* DROP CAP */
.drop-cap{font-family:var(--serif);font-size:clamp(52px,6vw,72px);float:left;line-height:.75;margin-right:8px;margin-top:8px;color:var(--saffron);font-weight:400;font-style:italic;text-shadow:0 0 30px rgba(232,160,64,.3)}

/* GLOWING KEYWORD */
.glow-word{color:var(--saffron);position:relative;font-weight:500}
.glow-word::after{content:'';position:absolute;bottom:-2px;left:0;width:100%;height:1px;background:var(--saffron);transform:scaleX(0);transform-origin:left;transition:transform .4s var(--ease)}
.glow-word:hover::after{transform:scaleX(1)}
.glow-word:hover{text-shadow:0 0 12px rgba(232,160,64,.35)}

/* ANIMATED HIGHLIGHT */
.text-reveal{background:linear-gradient(90deg,var(--saffron) 50%,transparent 50%);background-size:200% 100%;background-position:100% 0;-webkit-background-clip:text;background-clip:text;transition:background-position 1.2s var(--ease)}
.text-reveal.vis{background-position:0 0}

/* SECTION DIVIDER WITH ANIMATION */
.fancy-divider{display:flex;align-items:center;justify-content:center;gap:16px;padding:60px 0;opacity:.6}
.fancy-divider .fd-line{width:60px;height:1px;background:var(--saffron)}
.fancy-divider .fd-diamond{width:8px;height:8px;background:var(--saffron);transform:rotate(45deg);animation:diamondPulse 3s ease infinite}
@keyframes diamondPulse{0%,100%{opacity:.4;transform:rotate(45deg) scale(1)}50%{opacity:1;transform:rotate(45deg) scale(1.3)}}

/* FLOATING QUOTE MARKS */
.big-quote{font-family:var(--serif);font-size:200px;color:rgba(232,160,64,.06);position:absolute;line-height:1;pointer-events:none;font-weight:300}

/* TYPEWRITER CURSOR for section labels */
.sec-label::after{content:'|';color:var(--saffron);animation:blink 1s step-end infinite;margin-left:4px;font-weight:300}
@keyframes blink{50%{opacity:0}}

/* ENCOUNTER HOVER GLOW */
.enc:hover{box-shadow:inset 0 0 60px rgba(232,160,64,.04)}

/* SCROLL-TRIGGERED COUNTER for encounters */
.enc-num{font-family:var(--serif);font-size:72px;font-weight:300;color:rgba(232,160,64,.1);line-height:1;transition:color .5s,transform .5s}
.enc:hover .enc-num{color:rgba(232,160,64,.2);transform:scale(1.1)}

</style>
</head>
<body>

<!-- PROGRESS -->
<div id="progress"></div>

<!-- LOADER -->
<div class="loader" id="loader">
  <div class="loader-glyph">GSS</div>
  <div class="loader-sub">Global South Solidarities</div>
  <div class="loader-bar"><div class="loader-fill"></div></div>
</div>

<!-- CURSOR -->
<div class="cur" id="curDot"></div>
<div class="cur" id="curRing"></div>

<!-- PARTICLES -->
<canvas id="particles" style="position:fixed;inset:0;pointer-events:none;z-index:0"></canvas>

<!-- NAV -->
<nav>
  <div class="nav-logo"><span class="dot"></span> GSS Anarchive</div>
  <div class="nav-links">
    <a href="#">Archive</a>
    <a href="index.html">Home</a>
    <a href="#">GSS AI</a>
    <a href="#">Contribute</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <canvas id="heroCanvas"></canvas>
  <div class="parallax-lines" id="pLines"></div>
  <div class="hero-content">
    <div class="hero-label">About the Project</div>
    <h1>What is <em>Global South</em><br><em>Solidarities</em>?</h1>
    <p class="hero-sub"><span class="drop-cap">L</span>et’s begin with what the Global South is for us. “Global South” is not merely a geographic term for what was once called the Third World. It is not a synonym for “developing countries” or a polite way of saying “poor nations.” It is a political designation. It is a call for alliances.</p>
  </div>
  <div class="hero-gradient"></div>
  <div class="hero-scroll"><span>Scroll</span><div class="arr"></div></div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-track">
    <span class="ticker-item">Settler Colonialism <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Environmental Injustice <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Racialized Violence <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Epistemic Erasure <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Colonial <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Capitalist <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Heteropatriarchal <span class="sep">&#9670;</span></span>
    <span class="ticker-item">Imperial <span class="sep">&#9670;</span></span>
